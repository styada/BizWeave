{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": {
      "@/*": ["src/*"]
    },
    "lib": ["ES2022"]
  },
  "include": ["src/**/*", "../src/lib/agents/orchestrator.ts"],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
